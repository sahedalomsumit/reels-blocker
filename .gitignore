# Android & Kotlin / Gradle Projects .gitignore
# A modern, robust gitignore tailored for reels-blocker android application.

# Built Artifacts & Directories
/build
/*/build
/captures
.externalNativeBuild
.cxx

# Gradle Files and Caches
.gradle/
.kotlin/
build/
app/build/
.gradle-credentials.properties

# Android Studio & IntelliJ IDEA Config
*.iml
.idea/
!.idea/codeStyles/
!.idea/scopes/
!.idea/copyright/
!.idea/inspectionProfiles/

# Device & Simulator Files
*.apk
*.ap_
*.aab
*.dex
*.class

# Signing Keystores & Private Configuration
*.keystore
!debug.keystore
local.properties
.env
.env.*
google-services.json

# Log Files
*.log

# System & OS Specific Files
.DS_Store
Thumbs.db
desktop.ini
